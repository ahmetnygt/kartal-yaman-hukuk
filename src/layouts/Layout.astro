---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="tr">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Kartal Yaman Hukuk Bürosu - Profesyonel Hukuki Danışmanlık" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title} | Kartal Yaman Hukuk Bürosu</title>
        <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
	</head>
	<body>
        <div class="top-bar">
            <div class="container top-bar-container">
                <div class="top-info">
                    <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.27-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg> +90 555 555 55 55</span>
                    <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg> info@kartalyamanhukuk.com</span>
                </div>
                <div class="top-social">
                    <span>TR</span> | <span>EN</span>
                </div>
            </div>
        </div>

        <header class="site-header">
            <div class="container header-container">
                <a href="/" class="logo">
                    <span class="logo-main">KARTAL YAMAN</span>
                    <span class="logo-sep"></span>
                    <span class="logo-sub">HUKUK BÜROSU</span>
                </a>
                <nav class="main-nav">
                    <a href="/" class="active">ANA SAYFA</a>
                    <a href="/hakkimizda">HAKKIMIZDA</a>
                    <a href="/ekibimiz">EKİBİMİZ</a>
                    <a href="/faaliyet-alanlarimiz">FAALİYET ALANLARI</a>
                    <a href="/makaleler">MAKALELER</a>
                    <a href="/iletisim">İLETİŞİM</a>
                </nav>
            </div>
        </header>

		<main>
            <slot />
        </main>

        <footer class="site-footer">
            <div class="container footer-grid">
                <div class="footer-col">
                    <div class="footer-logo">
                        <span class="logo-main white">KARTAL YAMAN</span>
                        <span class="logo-sep"></span>
                        <span class="logo-sub">HUKUK BÜROSU</span>
                    </div>
                    <p class="footer-desc">Hukuki süreçlerinizde şeffaflık, dürüstlük ve profesyonellik ilkeleriyle yanınızdayız.</p>
                </div>
                
                <div class="footer-col">
                    <h4>HIZLI MENÜ</h4>
                    <ul class="footer-links">
                        <li><a href="/">Ana Sayfa</a></li>
                        <li><a href="/hakkimizda">Hakkımızda</a></li>
                        <li><a href="/makaleler">Makaleler</a></li>
                        <li><a href="/iletisim">İletişim</a></li>
                    </ul>
                </div>

                <div class="footer-col">
                    <h4>HİZMETLERİMİZ</h4>
                    <ul class="footer-links">
                        <li><a href="/faaliyet-alanlari">Ceza Hukuku</a></li>
                        <li><a href="/faaliyet-alanlari">İş Hukuku</a></li>
                        <li><a href="/faaliyet-alanlari">Aile Hukuku</a></li>
                    </ul>
                </div>

                <div class="footer-col">
                    <h4>İLETİŞİM</h4>
                    <div class="contact-info">
                        <p>Adres: Kartal Yaman Hukuk Plaza, İstanbul</p>
                        <p>Telefon: 0212 555 55 55</p>
                        <p>E-posta: info@kartalyamanhukuk.com</p>
                    </div>
                </div>
            </div>

            <div class="footer-bottom">
                <div class="container bottom-container">
                    <p>&copy; 2026 Kartal Yaman Hukuk Bürosu.</p>
                    <div class="baro-tags">
                        <span>BARO SİCİL NO: [SİCİL NO]</span>
                        <span>KEP: kartalyaman@hs01.kep.tr</span>
                    </div>
                </div>
            </div>
        </footer>
	</body>
</html>

<style>
    .container { max-width: 1140px; margin: 0 auto; padding: 0 20px; }

    /* LOGO TASARIMI (Çizgili Versiyon) */
    .logo, .footer-logo {
        display: flex;
        flex-direction: column;
        line-height: 1;
        width: fit-content;
    }
    .logo-main {
        font-family: 'Playfair Display', serif;
        font-size: 1.6rem;
        font-weight: 700;
        letter-spacing: 1px;
        color: var(--dark-green); /* Header için koyu yeşil */
    }
    .logo-main.white {
        color: var(--white); /* Footer için beyaz */
    }
    .logo-sep {
        height: 1px;
        background-color: var(--gold);
        width: 100%;
        margin: 4px 0;
    }
    .logo-sub {
        font-family: 'Inter', sans-serif;
        font-size: 0.65rem;
        color: var(--gold);
        letter-spacing: 4.5px;
        font-weight: 500;
        text-align: center;
    }

    /* TOP BAR & HEADER */
    .top-bar { background-color: var(--dark-green); padding: 10px 0; color: #A0B0AA; font-size: 0.8rem; }
    .top-bar-container { display: flex; justify-content: space-between; align-items: center; }
    .top-info { display: flex; gap: 20px; }
    .top-info span { display: flex; align-items: center; gap: 6px; }
    .icon { width: 14px; height: 14px; color: var(--gold); }

    .site-header { 
        background-color: var(--white); 
        padding: 20px 0; 
        position: sticky; 
        top: 0; 
        z-index: 1000; 
        box-shadow: 0 5px 20px rgba(0,0,0,0.05); 
    }
    .header-container { display: flex; justify-content: space-between; align-items: center; }
    .main-nav { display: flex; gap: 30px; align-items: center; }
    .main-nav a { 
        color: var(--text-main); 
        font-size: 0.85rem; 
        font-weight: 600; 
        letter-spacing: 1px; 
    }
    .main-nav a:hover, .main-nav a.active { color: var(--gold); }

    /* FOOTER */
    .site-footer { background-color: #0E1A17; color: #94A3B8; padding: 80px 0 0; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 50px; margin-bottom: 60px; }
    .footer-col h4 { color: var(--white); font-size: 1rem; margin-bottom: 25px; letter-spacing: 1px; }
    .footer-logo { margin-bottom: 20px; }
    .footer-desc { font-size: 0.9rem; line-height: 1.8; }
    .footer-links { list-style: none; }
    .footer-links li { margin-bottom: 12px; }
    .footer-links a { color: #94A3B8; font-size: 0.9rem; transition: color 0.3s; }
    .footer-links a:hover { color: var(--gold); }
    .footer-bottom { background-color: #0A1311; padding: 25px 0; border-top: 1px solid rgba(255,255,255,0.05); }
    .bottom-container { display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; color: #64748B; }
    .baro-tags { display: flex; gap: 20px; color: var(--gold); font-weight: 500; }

    @media (max-width: 992px) { .footer-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 768px) {
        .top-bar { display: none; }
        .header-container { flex-direction: column; gap: 15px; }
        .main-nav { flex-wrap: wrap; justify-content: center; }
        .footer-grid { grid-template-columns: 1fr; text-align: center; }
        .footer-logo { align-items: center; margin: 0 auto 20px; }
        .bottom-container { flex-direction: column; gap: 15px; text-align: center; }
    }
</style>