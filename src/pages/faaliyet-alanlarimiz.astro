---
import Layout from '../layouts/Layout.astro';

const calismaAlanlari = [
  {
    title: "Şirketler ve Ticaret Hukuku",
    description: "Şirket kurulumundan başlayıp, günlük ticari işlerde, hisse devrinde ve sözleşmelerde esnafın ve şirketin her türlü hukuki derdini çözeriz."
  },
  {
    title: "Sözleşmeler Hukuku",
    description: "Mal alım satımından ortaklık sözleşmelerine kadar, sonradan baş ağrıtmayacak, sağlam ve net sözleşmeler hazırlarız."
  },
  {
    title: "İş ve Sosyal Güvenlik Hukuku",
    description: "İşçi-işveren uyuşmazlıkları, iş kazaları ve arabuluculuk süreçlerinde her iki tarafın da hakkını koruyan net çözümler."
  },
  {
    title: "Ceza ve İnfaz Hukuku",
    description: "Soruşturma ve kovuşturma aşamalarında, müvekkilin hakkını sonuna kadar, büyük bir gizlilik ve titizlikle savunuruz."
  },
  {
    title: "Gayrimenkul Hukuku",
    description: "Tapu iptal, tescil, tahliye ve kira uyuşmazlıklarında; mülk sahibinin veya kiracının hakkını masada bırakmayız."
  },
  {
    title: "Aile ve Miras Hukuku",
    description: "Boşanma, nafaka, velayet ve miras paylaşımı gibi hassas konularda, ailenin mahremiyetini koruyarak en hızlı sonucu alırız."
  },
  {
    title: "İcra ve İflas Hukuku",
    description: "Alacağın tahsili veya haksız icra takiplerine karşı durma konusunda hızlı ve etkili haciz/kaldırma işlemleri."
  },
  {
    title: "Fikrî Mülkiyet Hukuku",
    description: "Marka, patent, endüstriyel tasarım tescilleri ve her türlü fikri mülkiyet haklarının ihlallerine karşı korunması."
  }
];
---

<Layout title="Faaliyet Alanlarımız">
  
  <section class="page-header">
    <div class="container">
      <h1>Faaliyet Alanlarımız</h1>
      <p>Müvekkillerimizin hakkını, kendi hakkımız gibi savunur; her türlü hukuki süreçte şeffaf, samimi ve sonuç odaklı hizmet veririz.</p>
    </div>
  </section>

  <section class="services-page">
    <div class="container">
      <div class="services-grid">
        {calismaAlanlari.map((alan) => (
          <div class="service-card">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path>
              </svg>
            </div>
            <h3>{alan.title}</h3>
            <p>{alan.description}</p>
            <a href="sirketler-ve-ticaret-hukuku" class="read-more">DETAYLI BİLGİ &rarr;</a>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  /* SAYFA ÜST BAŞLIĞI (HERO MİNİ) */
  .page-header {
    background-color: var(--dark-green);
    color: var(--white);
    padding: 50px 15px;
    text-align: center;
  }

  .page-header h1 {
    color: var(--white);
    font-size: 2.5rem;
    margin-bottom: 20px;
    font-family: 'Playfair Display', serif;
  }

  .page-header p {
    color: #A0B0AA;
    max-width: 650px;
    margin: 0 auto;
    font-size: 1.1rem;
    line-height: 1.8;
  }

  /* KARTLAR VE GRID (Ana sayfadaki ile aynı jilet yapı) */
  .services-page {
    padding: 80px 0 100px;
    background-color: var(--bg-cream);
  }

  .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px;
  }

  .service-card {
    background: var(--white);
    padding: 40px 35px;
    border-radius: 4px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
  }

  .card-icon {
    width: 55px;
    height: 55px;
    color: var(--gold);
    margin-bottom: 25px;
    background: rgba(180, 141, 82, 0.1);
    padding: 13px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-icon svg {
    width: 100%;
    height: 100%;
  }

  .service-card h3 {
    font-size: 1.3rem;
    margin-bottom: 15px;
    color: var(--dark-green);
    font-family: 'Playfair Display', serif;
  }

  .service-card p {
    color: var(--text-muted);
    margin-bottom: 30px;
    font-size: 0.95rem;
    line-height: 1.7;
    flex-grow: 1; /* Altındaki butonu en aşağı itmek için */
  }

  .read-more {
    color: var(--gold);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    display: inline-flex;
    align-items: center;
    margin-top: auto;
  }

  .read-more:hover {
    color: var(--gold-hover);
  }

  /* MOBİL AYARLAR */
  @media (max-width: 768px) {
    .page-header {
      padding: 60px 0;
    }
    .page-header h1 {
      font-size: 2.3rem;
    }
    .service-card {
      padding: 30px 25px;
    }
  }
</style>