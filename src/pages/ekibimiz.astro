---
import Layout from '../layouts/Layout.astro';

const teamMembers = [
  {
    name: "Av. Kartal Yaman",
    title: "Kurucu Ortak",
    desc: "Ceza Hukuku ve Şirketler Hukuku alanında 15 yılı aşkın tecrübesiyle büromuzun kurucusudur.",
    image: "/images/teammember.jpg"
  },
  {
    name: "Av. Zeynep Demir",
    title: "Kıdemli Avukat",
    desc: "Aile ve Miras Hukuku uyuşmazlıklarında uzmanlaşmış, arabuluculuk siciline kayıtlı avukatımızdır.",
    image: "/images/teammember.jpg"
  },
  {
    name: "Av. Burak Yılmaz",
    title: "Avukat",
    desc: "İş Hukuku ve İcra-İflas hukuku alanında müvekkillerimize dinamik ve hızlı çözümler sunmaktadır.",
    image: "/images/teammember.jpg"
  }
];
---

<Layout title="Ekibimiz">
  <section class="page-header">
    <div class="container">
      <h1>Hukuk Kadromuz</h1>
      <p>Alanında uzman, tecrübeli ve dinamik avukat kadromuzla hakkınızı sonuna kadar savunuyoruz.</p>
    </div>
  </section>

  <section class="team-section">
    <div class="container">
      <div class="team-grid">
        {teamMembers.map((member) => (
          <div class="team-card">
            <div class="card-image">
              <img src={member.image} alt={member.name} />
              <div class="image-overlay">
                <a href="mailto:info@kartalyamanhukuk.com">İletişime Geç</a>
              </div>
            </div>
            <div class="card-info">
              <h3>{member.name}</h3>
              <span class="member-title">{member.title}</span>
              <p>{member.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header { background-color: var(--dark-green); color: var(--white); padding: 50px 15px; text-align: center; }
  .page-header h1 { font-family: 'Playfair Display', serif; font-size: 2.5rem; margin-bottom: 15px; color: var(--white); }
  .page-header p { color: #A0B0AA; max-width: 650px; margin: 0 auto; line-height: 1.8; font-size: 1.1rem; }

  .team-section { padding: 50px; background-color: var(--bg-cream); }
  .team-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px; }

  .team-card { background: var(--white); border-radius: 4px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.03); transition: transform 0.3s ease; }
  .team-card:hover { transform: translateY(-5px); }

  .card-image { position: relative; overflow: hidden; aspect-ratio: 3/4; }
  .card-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .team-card:hover .card-image img { transform: scale(1.05); }
  
  .image-overlay { position: absolute; inset: 0; background: rgba(20, 36, 31, 0.8); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s ease; }
  .team-card:hover .image-overlay { opacity: 1; }
  .image-overlay a { color: var(--white); border: 1px solid var(--gold); padding: 10px 25px; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; transition: background 0.3s ease; }
  .image-overlay a:hover { background: var(--gold); }

  .card-info { padding: 30px; text-align: center; border-top: 3px solid var(--gold); }
  .card-info h3 { color: var(--dark-green); font-size: 1.4rem; font-family: 'Playfair Display', serif; margin-bottom: 5px; }
  .member-title { display: block; color: var(--gold); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; margin-bottom: 15px; }
  .card-info p { color: var(--text-muted); font-size: 0.95rem; line-height: 1.6; }

  @media (max-width: 768px) {
    .team-grid { gap: 30px; }
  }
</style>