---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content'; // render'ı buraya dahil ettik

export async function getStaticPaths() {
  const makaleler = await getCollection('makaleler');
  return makaleler.map(makale => ({
    params: { slug: makale.id }, // slug yerine id oldu
    props: { makale },
  }));
}

const { makale } = Astro.props;
const { Content } = await render(makale); // Yeni render fonksiyonu
---

<Layout title={makale.data.title}>
  <article class="single-article">
    <header class="article-header">
      <h1>{makale.data.title}</h1>
      <div class="meta">
        <span>Yazar: {makale.data.author}</span> | 
        <time>Tarih: {makale.data.date.toLocaleDateString('tr-TR')}</time>
      </div>
    </header>
    
    <div class="content-body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  /* CSS'e dokunmadım, aynı kalıyor */
  .single-article { max-width: 800px; margin: 0 auto; padding: 60px 20px; background: #fff; }
  .article-header { margin-bottom: 40px; border-bottom: 2px solid var(--bg-light); padding-bottom: 20px; }
  .article-header h1 { font-size: 2.5rem; margin-bottom: 10px; }
  .meta { color: var(--text-muted); font-size: 0.9rem; }
  .content-body { line-height: 1.8; color: var(--text-main); }
  .content-body :global(h2) { color: var(--primary-navy); margin-top: 30px; margin-bottom: 15px; }
  .content-body :global(p) { margin-bottom: 20px; }
</style>