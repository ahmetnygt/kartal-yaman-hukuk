---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content'; // render'ı buraya dahil ettik

export async function getStaticPaths() {
  const makaleler = await getCollection('makaleler');
  return makaleler.map(makale => ({
    params: { slug: makale.id }, // slug yerine id oldu
    props: { makale },
  }));
}

const { makale } = Astro.props;
const { Content } = await render(makale); // Yeni render fonksiyonu
---

<Layout title={makale.data.title}>
  <article class="single-article">
    <div class="back-link-wrapper">
      <a href="/makaleler" class="back-link">&larr; Tüm Makalelere Dön</a>
    </div>
    <header class="article-header">
      <h1>{makale.data.title}</h1>
      <div class="meta">
        <span>Yazar: {makale.data.author}</span> | 
        <time>Tarih: {makale.data.date.toLocaleDateString('tr-TR')}</time>
      </div>
    </header>
    
    <div class="content-body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  /* CSS'e dokunmadım, aynı kalıyor */
  .single-article { max-width: 800px; margin: 0 auto; padding: 60px 45px; background: #fff; }
  .meta { color: var(--text-muted); font-size: 0.9rem; }
  .content-body { line-height: 1.8; color: var(--text-main); }
  .article-header { margin-bottom: 40px; border-bottom: 2px solid #E2E8F0; padding-bottom: 20px; }
  .article-header h1 { font-size: 2.5rem; margin-bottom: 10px; font-family: 'Playfair Display', serif; color: var(--dark-green); }
  .content-body :global(h2) { color: var(--dark-green); margin-top: 40px; margin-bottom: 20px; font-family: 'Playfair Display', serif; }
  .content-body :global(h3) { color: var(--dark-green); margin-top: 30px; margin-bottom: 15px; font-family: 'Playfair Display', serif; }
  .back-link-wrapper { margin-bottom: 30px; }
  .back-link { color: var(--gold); font-size: 0.9rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
  .back-link:hover { color: var(--dark-green); }
</style>